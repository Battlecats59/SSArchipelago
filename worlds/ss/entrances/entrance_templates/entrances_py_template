class SSEntrance:
    """
    Docstring for SSEntrance
    
    
    """

    region: str
    name: str
    reversible: bool
    ss_name: str | None

    def __init__(self, region, name, world: "SSWorld" = None):
        self.region = region
        self.name = name
        self.world = world

        if len([ex for ex in EXIT_GRAPH if ex.entrance_region == self.region and ex.entrance_name == self.name]) == 1:
            ent_data = [ex for ex in EXIT_GRAPH if ex.entrance_region == self.region and ex.entrance_name == self.name].pop()
            if ent_data.direction == 2:
                self.reversible = True
            else:
                self.reversible = False
            self.ss_name = ent_data.ss_entrance_name
        elif self.region == "Upper Skyloft - Knight Academy" and self.name == "Link's Room":
            self.reversible = False
            self.ss_name = "Skyloft - Knight Academy - Start Entrance"
        else:
            self.reversible = False
            self.ss_name = None

    def toExit(self):
        return SSExit(self.region, self.name, world=self.world)

    def __eq__(self, other):
        if not isinstance(other, SSEntrance):
            return False
        return self.region == other.region and self.name == other.name
    
    def __hash__(self):
        return hash((self.region, self.name))

    def __str__(self):
        return f"{self.region} ({self.name})"

class SSExit:
    """
    Docstring for SSExit
    
    
    """

    region: str
    name: str
    reversible: bool
    can_shuffle: bool
    ss_name: str

    def __init__(self, region, name, world: "SSWorld" = None):
        self.region = region
        self.name = name
        self.world = world

        #print(f"{self.region} ({self.name})")
        ex_data = [ex for ex in EXIT_GRAPH if ex.exit_region == self.region and ex.exit_name == self.name].pop()
        if ex_data.direction == 2:
            self.reversible = True
        else:
            self.reversible = False
        self.can_shuffle = ex_data.can_shuffle
        self.ss_name = ex_data.ss_exit_name

    def link(self, entrance, reversible=False, plando=False, no_logic=False):
        if not isinstance(entrance, SSEntrance):
            raise Exception(f"Tried to link exit {self.region} ({self.name}) to a non-entrance")
        
        if not self.world:
            raise Exception(f"Tried to run SSExit link() function without a valid world")
        
        entrance_mapping = self.world.entrances.entrance_mapping

        if self in entrance_mapping.exits:
            raise Exception(f"Tried to link exit {self.region} ({self.name}) but exit is already linked")
        
        entrance_mapping.exits.append(self)
        entrance_mapping.entrances.append(entrance)
        entrance_mapping.mapping.add((self, entrance, plando))

        if not plando:
            # Remove from regions
            self.world.entrances.regions[self.region]["exits"].remove(self)
            if entrance.name != "Link's Room":
                self.world.entrances.regions[entrance.region]["entrances"].remove(entrance)

        if no_logic:
            self.world.get_region(self.region).add_exits(
                {entrance.region: f"{self.region} ({self.name}) --> {entrance.region}"},
                {entrance.region: lambda state: True}
            )
        else:
            self.world.get_region(self.region).add_exits(
                {entrance.region: f"{self.region} ({self.name}) --> {entrance.region}"},
                {entrance.region: self.world.entrances.exit_requirements(self.world, f"{self.region} - {self.name}")}
            )

        if reversible:
            SSExit(entrance.region, entrance.name, world=self.world).link(self.toEntrance(), reversible=False, plando=plando, no_logic=no_logic)

    def toEntrance(self):
        return SSEntrance(self.region, self.name, world=self.world)

    def __eq__(self, other):
        if not isinstance(other, SSExit):
            return False
        return self.region == other.region and self.name == other.name
    
    def __hash__(self):
        return hash((self.region, self.name))
    
    def __str__(self):
        return f"{self.region} ({self.name})"

class SSEntranceMapping:
    """
    
    """

    exits: list[SSExit]
    entrances: list[SSEntrance]
    mapping: set[tuple[SSExit, SSEntrance, bool]]

    def __init__(self, world: "SSWorld"):
        self.world = world
        self.exits = []
        self.entrances = []
        self.mapping = set()

    def output_entrance_mapping(self):
        return [(ex.ss_name, ent.ss_name) for ex, ent, plando in self.mapping if plando == False]